# ===== Frontend env (Vite) =====
# VITE_API_BASE_URL — base URL gọi lên backend.
#   - Dev:  giữ "/api" để đi qua Vite proxy tới http://localhost:5000 (xem vite.config.ts)
#   - Prod: set tuyệt đối, VD: https://api.zhongruan-lms.vn/api
VITE_API_BASE_URL=/api

# Target backend của Vite proxy (chỉ dùng lúc dev). Đổi nếu backend chạy port khác.
VITE_PROXY_TARGET=http://localhost:5000

# ===== Realtime Socket.io =====
# Trỏ tới HTTP origin của backend (KHÔNG có path /socket.io).
#   - Dev:  http://localhost:5000 (Vite proxy không forward WebSocket; socket phải
#           kết nối thẳng tới backend port — tránh ws upgrade bị chặn).
#   - Prod: đặt tuyệt đối, VD: https://api.zhongruan-lms.vn
# Nếu bỏ trống: mặc định lấy từ window.location.origin (cùng host với FE — chỉ
# chạy đúng khi BE reverse-proxy /socket.io chung host với FE).
VITE_SOCKET_URL=http://localhost:5000
