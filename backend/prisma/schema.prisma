generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    Int            @id @default(autoincrement())
  fullName              String
  email                 String         @unique
  phone                 String?
  /// Địa chỉ liên hệ — user tự cập nhật trong Hồ sơ cá nhân. Nullable.
  address               String?
  passwordHash          String
  role                  Role           @default(STUDENT)
  status                UserStatus     @default(ACTIVE)
  resetToken            String?
  resetTokenExpiresAt   DateTime?
  refreshTokenHash      String?
  refreshTokenExpiresAt DateTime?
  /// Ảnh đại diện — FK UploadFile, nullable. Chỉ user tự thay đổi avatar của mình.
  avatarFileId          Int?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  deletedAt             DateTime?
  /// User thực hiện soft-delete (admin/support). Nullable vì record cũ chưa track.
  deletedById           Int?
  auditLogs             AuditLog[]
  notifications         Notification[]
  uploads               UploadFile[]   @relation("UserUploads")
  avatarFile            UploadFile?    @relation("UserAvatar", fields: [avatarFileId], references: [id], onDelete: SetNull)
  searchHistories       SearchHistory[]
  deletedNotifications  Notification[] @relation("NotificationDeletedBy")
  deletedUploads        UploadFile[]   @relation("UploadFileDeletedBy")
  deletedSettings       Setting[]      @relation("SettingDeletedBy")
  deletedTeachers       Teacher[]      @relation("TeacherDeletedBy")
  deletedPricingPlans   PricingPlan[]  @relation("PricingPlanDeletedBy")
  linkedTeachers        Teacher[]      @relation("TeacherLinkedUser")

  @@index([avatarFileId])
  @@index([deletedById])
}

/// Lịch sử từ khóa Global Search của từng user — dùng để gợi ý recent keywords.
/// Cascade delete khi user bị xoá vĩnh viễn (deleteUser đã xử lý soft-delete cho user).
model SearchHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  /// Từ khoá đã search (trim + lowercase ở app layer). Không unique — cho phép lặp.
  keyword   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("search_histories")
  @@index([userId, createdAt(sort: Desc)])
  @@index([keyword])
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String // VD: "AUTH_LOGIN_SUCCESS", "USER_CREATED", ...
  target    String? // VD: "User:13", "Auth:me"
  meta      Json? // Thông tin thêm tuỳ action
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id          Int              @id @default(autoincrement())
  userId      Int
  type        NotificationType @default(INFO)
  title       String
  message     String
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  deletedById Int?

  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  deletedBy   User? @relation("NotificationDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isRead])
  @@index([deletedAt])
  @@index([deletedById])
  @@map("notifications")
}

model UploadFile {
  id           Int       @id @default(autoincrement())
  originalName String
  storedName   String    @unique
  mimeType     String
  size         Int
  path         String
  uploadedById Int
  uploadedBy   User      @relation("UserUploads", fields: [uploadedById], references: [id])
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  deletedById  Int?
  avatarOf     User[]    @relation("UserAvatar")
  deletedBy    User?     @relation("UploadFileDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([uploadedById])
  @@index([deletedAt])
  @@index([deletedById])
  @@map("upload_files")
}

model Setting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String // Lưu JSON string để linh hoạt (true/false, số, chuỗi đa ngôn ngữ)
  description String?
  /// Nhóm cấu hình (General | Security | Upload | Notification | System).
  /// Nullable để giữ backward-compatible với row đã tạo trước khi phân nhóm.
  group       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deletedById Int?
  deletedBy   User?    @relation("SettingDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([key])
  @@index([group])
  @@index([deletedAt])
  @@index([deletedById])
  @@map("settings")
}

/// Hồ sơ giảng viên công khai — hiển thị trên trang /giang-vien (public site).
/// Tách khỏi User (User là tài khoản đăng nhập; Teacher là profile giảng dạy)
/// để Admin có thể quản lý hồ sơ độc lập với tài khoản.
/// Soft-delete theo đúng pattern của 4 model còn lại (deletedAt + deletedById).
/// Slug @unique dùng cho URL public /giang-vien/:slug; auto-generate từ fullName
/// nếu không truyền, cho phép Admin sửa tay khi trùng.
model Teacher {
  id                String   @id @default(uuid())
  fullName          String
  /// URL-friendly slug — sinh tự động (unidecode + kebab-case) từ fullName,
  /// Admin có thể sửa tay nếu trùng. Unique.
  slug              String   @unique
  /// Học vị / chức danh, vd "Thạc sĩ Ngôn ngữ Trung Quốc".
  title             String
  /// Mô tả dài cho trang chi tiết. Dùng String (không @db.Text) theo pattern chung của project.
  bio               String
  /// Mô tả ngắn 1–2 câu cho card danh sách.
  bioShort          String
  /// Link ảnh đại diện (CDN hoặc /uploads/...). Nullable — FE dùng ImagePlaceholder.
  avatarUrl         String?
  /// Số năm kinh nghiệm giảng dạy. Nullable cho giảng viên mới.
  yearsOfExperience Int?
  /// Chuyên môn, vd ["HSK 4-6", "Luyện thi", "Giao tiếp thương mại"].
  specialties       String[]
  /// Đánh dấu nổi bật — ưu tiên hiển thị + prerender SEO riêng.
  isFeatured        Boolean  @default(false)
  /// Cho phép ẩn tạm mà không cần xoá.
  isPublished       Boolean  @default(true)
  /// Thứ tự hiển thị tùy chỉnh (sort tăng dần).
  displayOrder      Int      @default(0)
  /// Tham chiếu nội bộ (nullable) tới User.role=teacher — để Admin đối chiếu
  /// nhanh giữa hồ sơ công khai và tài khoản đăng nhập. KHÔNG đồng bộ dữ liệu
  /// 2 chiều: Teacher vẫn là dữ liệu marketing độc lập. SetNull nếu user bị xoá.
  linkedUserId      Int?
  linkedUser        User?    @relation("TeacherLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  deletedById       Int?
  deletedBy         User?    @relation("TeacherDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([isPublished])
  @@index([isFeatured])
  @@index([displayOrder])
  @@index([deletedAt])
  @@index([deletedById])
  @@index([linkedUserId])
  @@map("teachers")
}

/// Liên hệ từ form public — khách truy cập website gửi yêu cầu tư vấn/hỗ trợ.
/// Khác với User (tài khoản đăng nhập) và Notification (thông báo nội bộ),
/// ContactRequest là lead từ public, không cần auth để tạo.
/// Soft-delete theo đúng pattern (deletedAt + deletedById) để Admin xử lý
/// rồi xoá khi cần, đồng thời đưa vào Trash Manager như các module khác.
model ContactRequest {
  id          String    @id @default(uuid())
  fullName    String
  phone       String
  email       String
  /// Nội dung khách muốn liên hệ — lưu TEXT (Postgres @db.Text) vì có thể dài.
  message     String    @db.Text
  /// NEW (mới) | CONTACTED (đã liên hệ) | CLOSED (đã xử lý xong).
  /// Lưu String thay vì enum để tránh phải thêm enum Postgres khi cần mở rộng.
  status      String    @default("NEW")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  deletedById Int?

  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([deletedById])
  @@map("contact_requests")
}

/// Gói học phí hiển thị trên trang /bang-gia (public) và quản lý qua Admin UI.
/// Soft-delete theo đúng pattern (deletedAt + deletedById).
model PricingPlan {
  id            String    @id @default(uuid())
  /// Tên gói, VD "HSK Sơ cấp (HSK 1-2) — Lớp nhóm".
  name          String
  /// "GROUP" (lớp nhóm) | "PRIVATE" (1 kèm 1).
  classType     String
  /// Giá bán (VNĐ). Không âm.
  price         Int
  /// Đơn vị: "buổi" | "tháng" | "khóa".
  priceUnit     String
  /// Giá gốc (nullable) — hiện gạch ngang nếu có khuyến mãi.
  originalPrice Int?
  /// Mô tả ngắn 1–2 câu.
  description   String
  /// Danh sách quyền lợi, VD ["Tặng giáo trình", "Học thử miễn phí 2 buổi"].
  features      String[]
  /// Slug khóa học liên kết (nullable) — tham chiếu tới coursesContent slug.
  courseSlug    String?
  /// Đánh dấu "Phổ biến nhất" nổi bật trên UI.
  isFeatured    Boolean   @default(false)
  /// Ẩn tạm mà không cần xoá.
  isPublished   Boolean   @default(true)
  /// Thứ tự hiển thị (sort tăng dần).
  displayOrder  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  Int?
  deletedBy    User?     @relation("PricingPlanDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([classType])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([displayOrder])
  @@index([deletedAt])
  @@index([deletedById])
  @@index([courseSlug])
  @@map("pricing_plans")
}
