generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    Int            @id @default(autoincrement())
  fullName              String
  email                 String         @unique
  phone                 String?
  /// Địa chỉ liên hệ — user tự cập nhật trong Hồ sơ cá nhân. Nullable.
  address               String?
  passwordHash          String
  role                  Role           @default(STUDENT)
  status                UserStatus     @default(ACTIVE)
  resetToken            String?
  resetTokenExpiresAt   DateTime?
  refreshTokenHash      String?
  refreshTokenExpiresAt DateTime?
  /// Ảnh đại diện — FK UploadFile, nullable. Chỉ user tự thay đổi avatar của mình.
  avatarFileId          Int?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  deletedAt             DateTime?
  /// User thực hiện soft-delete (admin/support). Nullable vì record cũ chưa track.
  deletedById           Int?
  auditLogs             AuditLog[]
  notifications         Notification[]
  uploads               UploadFile[]   @relation("UserUploads")
  avatarFile            UploadFile?    @relation("UserAvatar", fields: [avatarFileId], references: [id], onDelete: SetNull)
  searchHistories       SearchHistory[]
  deletedNotifications  Notification[] @relation("NotificationDeletedBy")
  deletedUploads        UploadFile[]   @relation("UploadFileDeletedBy")
  deletedSettings       Setting[]      @relation("SettingDeletedBy")

  @@index([avatarFileId])
  @@index([deletedById])
}

/// Lịch sử từ khóa Global Search của từng user — dùng để gợi ý recent keywords.
/// Cascade delete khi user bị xoá vĩnh viễn (deleteUser đã xử lý soft-delete cho user).
model SearchHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  /// Từ khoá đã search (trim + lowercase ở app layer). Không unique — cho phép lặp.
  keyword   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("search_histories")
  @@index([userId, createdAt(sort: Desc)])
  @@index([keyword])
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String // VD: "AUTH_LOGIN_SUCCESS", "USER_CREATED", ...
  target    String? // VD: "User:13", "Auth:me"
  meta      Json? // Thông tin thêm tuỳ action
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id          Int              @id @default(autoincrement())
  userId      Int
  type        NotificationType @default(INFO)
  title       String
  message     String
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  deletedById Int?

  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  deletedBy   User? @relation("NotificationDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isRead])
  @@index([deletedAt])
  @@index([deletedById])
  @@map("notifications")
}

model UploadFile {
  id           Int       @id @default(autoincrement())
  originalName String
  storedName   String    @unique
  mimeType     String
  size         Int
  path         String
  uploadedById Int
  uploadedBy   User      @relation("UserUploads", fields: [uploadedById], references: [id])
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  deletedById  Int?
  avatarOf     User[]    @relation("UserAvatar")
  deletedBy    User?     @relation("UploadFileDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([uploadedById])
  @@index([deletedAt])
  @@index([deletedById])
  @@map("upload_files")
}

model Setting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String // Lưu JSON string để linh hoạt (true/false, số, chuỗi đa ngôn ngữ)
  description String?
  /// Nhóm cấu hình (General | Security | Upload | Notification | System).
  /// Nullable để giữ backward-compatible với row đã tạo trước khi phân nhóm.
  group       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deletedById Int?
  deletedBy   User?    @relation("SettingDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([key])
  @@index([group])
  @@index([deletedAt])
  @@index([deletedById])
  @@map("settings")
}
